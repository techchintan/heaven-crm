{
  "name": "heavenpro-crm",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "@portabletext/react": "6.1.0"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "prebuild": "pnpm run typegen && pnpm run lint && pnpm run format"
  },
  "dependencies": {
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.24.0",
    "clsx": "^2.1.1",
    "next": "16.2.6",
    "next-sanity": "^12.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.24.0",
    "sanity-plugin-media": "^4.2.0",
    "styled-components": "^6.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
